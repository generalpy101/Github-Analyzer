{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "GitHub Review",
  "version": "1.0.0",
  "identifier": "com.github-review.desktop",
  "build": {
    "beforeDevCommand": "python3 app.py &",
    "devUrl": "http://localhost:5959",
    "beforeBuildCommand": "",
    "frontendDist": "http://localhost:5959"
  },
  "app": {
    "windows": [
      {
        "title": "GitHub Review",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/github-review-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
